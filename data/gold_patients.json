{
  "meta": {
    "name": "CKD Between-Visit Agent — gold patient set",
    "version": "1.0",
    "purpose": "Doubles as demo material and the scored eval set. No real PHI; all patients are synthetic.",
    "guideline_basis": "KDIGO 2024 CKD",
    "units": {
      "egfr": "mL/min/1.73m^2 (lab-reported CKD-EPI 2021, race-free)",
      "acr_mg_g": "urine albumin-creatinine ratio in mg/g. A1 <30, A2 30-300, A3 >300. (divide by ~8.84 for mg/mmol)",
      "potassium_mmol_l": "serum potassium, mmol/L",
      "creatinine_mg_dl": "serum creatinine, mg/dL"
    },
    "lab_flags": {
      "acute_illness": "value drawn during acute illness / hospitalisation — non-steady-state, exclude from slope",
      "trimethoprim_course": "on trimethoprim (or cimetidine) — inhibits tubular creatinine secretion, causes pseudo-rise",
      "low_muscle_mass": "cachexia/frailty/amputee/low muscle — creatinine-based eGFR unreliable, confirm cystatin C"
    },
    "expected_schema": {
      "ckd": "bool — does the patient meet the KDIGO CKD definition gate",
      "stage": "CGA string, e.g. 'G3a A3' (null if not CKD)",
      "risk_tier": "green | yellow | orange | red (null if not CKD)",
      "surface": "array of items the agent MUST surface, ranked by priority (1 = highest)",
      "suppress": "array of items the agent MUST consider and deliberately withhold, each with a reason"
    },
    "scoring_note": "Eval harness scores an exact-match on surfaced item types/drugs and on suppressed item types. Priority ordering scored on the hero only."
  },

